# ============================================================
# .env.example — Copy this to .env and fill in your own keys
# NEVER commit the real .env file
# ============================================================

# ── OpenRouter (AI Grading) ───────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=school-saas-grading
OPENROUTER_SITE_URL=http://localhost:8501

# ── Google Cloud Vision (OCR) ────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account.json

# ── Solana Blockchain (Payments) ──────────────────────────────
SOLANA_NETWORK=devnet
# SOLANA_NETWORK=mainnet-beta   ← uncomment for production
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_RECEIVER_WALLET=YOUR_SOLANA_WALLET_PUBLIC_ADDRESS_HERE

# ── Solana Payment Limits & Timeouts ─────────────────────────
SOLANA_PAYMENT_TIMEOUT=900         # seconds (15 min)
SOLANA_CONFIRMATION_TIMEOUT=120    # seconds
SOLANA_MIN_CONFIRMATIONS=3
MIN_SOL_AMOUNT=0.01
MAX_SOL_AMOUNT=100.0

# ── Currency Fallback Rates (used if CoinGecko API is down) ──
FALLBACK_SOL_USD_RATE=142.50
FALLBACK_USD_PKR_RATE=277.50
PRICE_CACHE_SECONDS=300

# ── Debug ─────────────────────────────────────────────────────
DEBUG_BLOCKCHAIN=false
