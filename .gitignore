# ============================================================
# .gitignore — SC Portals (School SaaS Platform)
# ============================================================

# --- Secrets ---
.env
*.pem
*.key

# --- Python ---
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
*.egg
.Python
build/
dist/

# --- Virtual environments ---
venv/
.venv/
env/
ENV/

# --- Database (generated locally; run the seeders to populate) ---
backend/*.db
backend/*.sqlite3
*.db-journal

# --- Runtime / generated data ---
uploads/*
!uploads/.gitkeep
!uploads/receipts/
uploads/receipts/*
!uploads/receipts/.gitkeep
processed/*
!processed/.gitkeep
results/*
!results/.gitkeep
logs/
*.log

# --- Streamlit ---
.streamlit/secrets.toml

# --- Editor / OS junk ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- macOS zip artifacts ---
__MACOSX/
